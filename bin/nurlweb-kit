#!/bin/sh
# nurlweb-kit/bin/nurlweb-kit вЂ” Convention Layer CLI
#
# Usage:
#   nurlweb-kit new <name>                            Scaffold project
#   nurlweb-kit g scaffold <name> <field:type ...>    Working CRUD + tests
#   nurlweb-kit g controller <name>                   Controller with 5 handlers
#   nurlweb-kit g service <name>                      Service with CRUD functions
#   nurlweb-kit g model <name> <field:type ...>       ORM model wrapper
#   nurlweb-kit check                                 Validate conventions
#   nurlweb-kit dev                                   Build + run + watch
#   nurlweb-kit version                               Print version
#   nurlweb-kit help                                  Print help

set -eu

VERSION="0.2.0.0"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
KIT_DIR="$(dirname "$SCRIPT_DIR")"

# в”Ђв”Ђ help в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

print_help() {
    cat <<EOF
nurlweb-kit v${VERSION} вЂ” Convention Layer CLI for NurlWeb

Usage:
  nurlweb-kit new <name>                            Scaffold project
  nurlweb-kit g scaffold <name> <field:type ...>    Working CRUD + tests
  nurlweb-kit g controller <name>                   Controller with 5 handlers
  nurlweb-kit g service <name>                      Service with CRUD functions
  nurlweb-kit g model <name> <field:type ...>       ORM model wrapper
  nurlweb-kit check                                 Validate conventions
  nurlweb-kit dev                                   Build + run + watch
  nurlweb-kit version                               Print version
  nurlweb-kit help                                  Print help

Examples:
  nurlweb-kit new blog
  cd blog && nurlweb-kit g scaffold post title:s body:s
  nurlweb-kit check
  nurlweb-kit dev
EOF
}

# в”Ђв”Ђ new в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_new() {
    local name="$1"
    if [ -d "$name" ]; then
        echo "Error: directory '$name' already exists" >&2
        exit 1
    fi

    echo "Creating nurlweb-kit project: $name"
    mkdir -p \
        "$name/config" \
        "$name/controllers" \
        "$name/services" \
        "$name/models" \
        "$name/middleware" \
        "$name/templates" \
        "$name/tests"

    # main.nu вЂ” entry point with config + lifecycle + example route
    cat > "$name/main.nu" <<NUREF
// $name/main.nu вЂ” Generated by nurlweb-kit v${VERSION}

\$ \`nurlweb/nurlweb.nu\`
\$ \`nurlweb-kit/config.nu\`
\$ \`nurlweb-kit/lifecycle.nu\`
\$ \`nurlweb-kit/logger.nu\`

@ main в†’ i {
    // в”Ђв”Ђ Config в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    : s env \`dev\`
    : Config cfg ( kit_config_load env )
    // ( kit_config_set cfg \`port\` \`3900\` \`i\` )
    // ( kit_config_expect cfg \`port\` \`i\` )

    // в”Ђв”Ђ Lifecycle в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    : Lifecycle lc ( kit_lifecycle_new )

    // в”Ђв”Ђ App в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    : i port 3900
    : App app ( app_new \`127.0.0.1\` port )

    // в”Ђв”Ђ Logging в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    ( kit_with_logger app )
    ( kit_log_info \`server starting...\` )

    // в”Ђв”Ђ Routes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    ( app_get app \`/\`
            ^ ( response_text 200 \`hello from $name!\\n\` )
        })

    // в”Ђв”Ђ Start в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    : !v LifecycleErr lc_result ( kit_lifecycle_run_before_start lc app )
    ?? lc_result {
        T err в†’ {
            // before_start hooks failed вЂ” do not start server
            ( nurl_print \`lifecycle error, aborting\\n\` )
            ^ 1
        }
        F _ в†’ {}
    }

    ( nurl_print \`$name on http://127.0.0.1:\` )
    ( nurl_print_int port )
    ( nurl_print \`\\n\` )

    : !v NetErr rr ( app_serve app )

    ( kit_lifecycle_run_before_stop lc app )
    ( kit_lifecycle_free lc )
    ( kit_config_free cfg )
    ( app_free app )

    ?? rr {
        T _ в†’ { ^ 0 }
        F _ в†’ { ^ 1 }
    }
}
NUREF

    # config/_default.nu
    cat > "$name/config/_default.nu" <<NUREF
// config/_default.nu вЂ” Base configuration (always loaded)
// Add your default config values here.
// Use kit_config_set to populate values at startup.
NUREF

    # config/_prod.nu
    cat > "$name/config/_prod.nu" <<NUREF
// config/_prod.nu вЂ” Production overrides
// This file should be added to .gitignore.
NUREF

    # build.sh
    cat > "$name/build.sh" <<BUILDEF
#!/bin/sh
# $name/build.sh вЂ” Build script
set -eu

NURLC="\${NURLC:-nurlc}"
RUNTIME="\${NURL_RUNTIME:-nurlweb/../stdlib/runtime.o}"

echo "Building $name..."
"\$NURLC" main.nu > app.ll 2>/dev/null
clang -O2 app.ll "\$RUNTIME" -lm -lpthread \\
    \$(pkg-config --libs libcurl 2>/dev/null || echo "-lcurl") \\
    \$(pkg-config --libs openssl 2>/dev/null || echo "-lssl -lcrypto") \\
    \$(pkg-config --libs sqlite3 2>/dev/null || echo "-lsqlite3") \\
    \$(pkg-config --libs zlib 2>/dev/null || echo "-lz") \\
    \$(pkg-config --libs libzstd 2>/dev/null || echo "-lzstd") \\
    -o app 2>/dev/null
echo "Done. Run: ./app"
BUILDEF
    chmod +x "$name/build.sh"

    # .gitignore
    cat > "$name/.gitignore" <<'GIEOF'
*.ll
*.o
app
config/_prod.nu
GIEOF

    echo ""
    echo "Project '$name' created!"
    echo ""
    echo "  cd $name"
    echo "  sh build.sh"
    echo "  ./app"
    echo ""
    echo "Then open http://127.0.0.1:3900"
}

# в”Ђв”Ђ g scaffold в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_g_scaffold() {
    local name="$1"
    shift
    local fields="$*"

    echo "Scaffolding $name..."

    # Controller
    cmd_g_controller "$name"

    # Service
    cmd_g_service "$name"

    # Model
    cmd_g_model "$name" $fields

    # Test stubs
    cat > "tests/test_${name}.nu" <<NUREF
// tests/test_${name}.nu вЂ” Generated by nurlweb-kit

\$ \`nurlweb/app.nu\`
\$ \`nurlweb-kit/controller.nu\`

// Test: GET /${name}s в†’ 200 (index)
// Test: GET /${name}s/:id в†’ 200 (show)
// Test: POST /${name}s в†’ 201 (create)
// Test: PUT /${name}s/:id в†’ 200 (update)
// Test: DELETE /${name}s/:id в†’ 204 (delete)

@ test_${name}_index в†’ i {
    // TODO: write index test
    ^ 0
}

@ test_${name}_show в†’ i {
    // TODO: write show test
    ^ 0
}

@ test_${name}_create в†’ i {
    // TODO: write create test
    ^ 0
}

@ test_${name}_update в†’ i {
    // TODO: write update test
    ^ 0
}

@ test_${name}_delete в†’ i {
    // TODO: write delete test
    ^ 0
}
NUREF

    echo "Scaffold complete: controller, service, model, and tests for '$name'."
    echo "Add these routes to main.nu (import controller first):"
    echo ""
    printf '  $ `controllers/%s.nu`\n' "$name"
    echo ""
    printf '  ( app_get app `/api/%ss` \\ HttpRequest req Params p -> HttpResponse { ^ ( %s_index req p ) })\n' "$name" "$name"
    printf '  ( app_get app `/api/%ss/:id` \\ HttpRequest req Params p -> HttpResponse { ^ ( %s_show req p ) })\n' "$name" "$name"
    printf '  ( app_post app `/api/%ss` \\ HttpRequest req Params p -> HttpResponse { ^ ( %s_create req p ) })\n' "$name" "$name"
    printf '  ( app_put app `/api/%ss/:id` \\ HttpRequest req Params p -> HttpResponse { ^ ( %s_update req p ) })\n' "$name" "$name"
    printf '  ( app_delete app `/api/%ss/:id` \\ HttpRequest req Params p -> HttpResponse { ^ ( %s_delete req p ) })\n' "$name" "$name"
}
cmd_g_controller() {
    local name="$1"

    cat > "controllers/${name}.nu" <<NUREF
// controllers/${name}.nu вЂ” Generated by nurlweb-kit

\$ \`nurlweb/nurlweb.nu\`

@ ${name}_index HttpRequest req Params params в†’ HttpResponse {
    // GET /api/${name}s вЂ” list all ${name}s
    ^ ( response_text 200 \`[]\\n\` )
}

@ ${name}_show HttpRequest req Params params в†’ HttpResponse {
    // GET /api/${name}s/:id вЂ” get one ${name}
    ^ ( response_text 200 \`{}\\n\` )
}

@ ${name}_create HttpRequest req Params params в†’ HttpResponse {
    // POST /api/${name}s вЂ” create ${name}
    ^ ( response_text 201 \`{}\\n\` )
}

@ ${name}_update HttpRequest req Params params в†’ HttpResponse {
    // PUT /api/${name}s/:id вЂ” update ${name}
    ^ ( response_text 200 \`ok\\n\` )
}

@ ${name}_delete HttpRequest req Params params в†’ HttpResponse {
    // DELETE /api/${name}s/:id вЂ” delete ${name}
    ^ ( response_text 204 \`\` )
}
NUREF

    echo "Created controllers/${name}.nu"
}

# в”Ђв”Ђ g service в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_g_service() {
    local name="$1"

    cat > "services/${name}_service.nu" <<NUREF
// services/${name}_service.nu вЂ” Generated by nurlweb-kit

// Pure functions for ${name} business logic.
// Import and call directly вЂ” no DI, no registry.

// @ find_${name} OrmDB db i id в†’ !OrmRow DbErr { ... }
// @ create_${name} OrmDB db s name s email в†’ !i DbErr { ... }
// @ update_${name} OrmDB db i id s name в†’ !i DbErr { ... }
// @ delete_${name} OrmDB db i id в†’ !i DbErr { ... }
NUREF

    echo "Created services/${name}_service.nu"
}

# в”Ђв”Ђ g model в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_g_model() {
    local name="$1"
    shift
    local fields="$*"

    # Build field list for schema
    local schema=""
    for field in $fields; do
        local fname=$(echo "$field" | cut -d: -f1)
        local ftype=$(echo "$field" | cut -d: -f2-)
        schema="${schema}    ${fname} ${ftype}\n"
    done

    cat > "models/${name}.nu" <<NUREF
// models/${name}.nu вЂ” Generated by nurlweb-kit

\$ \`nurlweb/orm.nu\`

// Model fields:
// $(echo "$fields" | tr ' ' '\n' | while read f; do echo "  $f"; done)

// TODO: define ${name} struct and orm wrapper functions
// @ ${name}_create_table OrmDB db в†’ !i DbErr { ... }
// @ ${name}_insert OrmDB db OrmParam p1 ... в†’ !i DbErr { ... }
// @ ${name}_find OrmDB db i id в†’ !OrmRow DbErr { ... }
// @ ${name}_find_all OrmDB db в†’ !( Vec OrmRow ) DbErr { ... }
// @ ${name}_delete OrmDB db i id в†’ !i DbErr { ... }
NUREF

    echo "Created models/${name}.nu"
}

# в”Ђв”Ђ check в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_check() {
    local errors=0

    echo "Checking project conventions..."

    # Check config directory
    if [ ! -f "config/_default.nu" ]; then
        echo "  FAIL: config/_default.nu missing"
        errors=$((errors + 1))
    else
        echo "  OK: config/_default.nu exists"
    fi

    # Check .gitignore
    if [ ! -f ".gitignore" ]; then
        echo "  FAIL: .gitignore missing"
        errors=$((errors + 1))
    elif ! grep -q "config/_prod.nu" .gitignore 2>/dev/null; then
        echo "  FAIL: .gitignore missing config/_prod.nu entry"
        errors=$((errors + 1))
    else
        echo "  OK: .gitignore has config/_prod.nu"
    fi

    # Check controllers export expected functions
    for ctrl in controllers/*.nu; do
        [ -f "$ctrl" ] || continue
        local name=$(basename "$ctrl" .nu)
        for action in index show create update delete; do
            if ! grep -q "@ ${name}_${action}" "$ctrl" 2>/dev/null; then
                echo "  WARN: $ctrl missing ${name}_${action} function"
            fi
        done
        echo "  OK: $ctrl checked"
    done

    # Check main.nu exists
    if [ ! -f "main.nu" ]; then
        echo "  FAIL: main.nu missing"
        errors=$((errors + 1))
    else
        echo "  OK: main.nu exists"
    fi

    if [ "$errors" -eq 0 ]; then
        echo "All checks passed."
        exit 0
    else
        echo "$errors error(s) found."
        exit 1
    fi
}

# в”Ђв”Ђ dev в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_dev() {
    echo "Starting dev mode..."
    echo "Building..."

    sh build.sh

    echo "Running app..."
    ./app &
    local pid=$!

    echo "Watching for .nu file changes (Ctrl+C to stop)..."

    # Use fswatch if available, otherwise inotifywait
    if command -v fswatch >/dev/null 2>&1; then
        fswatch -r -e ".*" -i "\\.nu$" . | while read line; do
            echo "Change detected: $line вЂ” rebuilding..."
            kill "$pid" 2>/dev/null || true
            sh build.sh && {
                ./app &
                pid=$!
                echo "Restarted (pid $pid)"
            }
        done
    elif command -v inotifywait >/dev/null 2>&1; then
        while inotifywait -r -e modify --include "\\.nu$" .; do
            echo "Change detected вЂ” rebuilding..."
            kill "$pid" 2>/dev/null || true
            sh build.sh && {
                ./app &
                pid=$!
                echo "Restarted (pid $pid)"
            }
        done
    else
        echo "No file watcher found. Install fswatch or inotify-tools for auto-rebuild."
        echo "Running without watch. Press Ctrl+C to stop."
        wait "$pid"
    fi
}

# в”Ђв”Ђ version в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

print_version() {
    echo "nurlweb-kit v${VERSION}"
}

# в”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

case "${1:-help}" in
    new)
        [ $# -lt 2 ] && { echo "Usage: nurlweb-kit new <name>" >&2; exit 1; }
        cmd_new "$2"
        ;;
    g)
        [ $# -lt 3 ] && { echo "Usage: nurlweb-kit g <scaffold|controller|service|model> <name>" >&2; exit 1; }
        case "$2" in
            scaffold) cmd_g_scaffold "$3" "${@:4}" ;;
            controller) cmd_g_controller "$3" ;;
            service) cmd_g_service "$3" ;;
            model) cmd_g_model "$3" "${@:4}" ;;
            *) echo "Unknown generator: $2" >&2; exit 1 ;;
        esac
        ;;
    check) cmd_check ;;
    dev) cmd_dev ;;
    version) print_version ;;
    help|--help|-h) print_help ;;
    *) echo "Unknown command: $1" >&2; print_help; exit 1 ;;
esac
