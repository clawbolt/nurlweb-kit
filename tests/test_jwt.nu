// nurlweb/test_jwt.nu вЂ” Compile-time unit tests for auth_jwt.nu
//
// Run: ./build/nurlc nurlweb/test_jwt.nu
// Expected: exit 0 (clean compile)

$ `nurlweb-kit/middleware/auth_jwt.nu`

// в”Ђв”Ђ jwt_sign returns a string в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

@ test_jwt_sign в†’ s {
    ^ ( jwt_sign `hello` `secret123` )
}

// в”Ђв”Ђ jwt_verify returns ?String в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

@ test_jwt_verify в†’ ?String {
    : s token ( jwt_sign `data` `key` )
    ^ ( jwt_verify token `key` )
}

// в”Ђв”Ђ jwt_verify wrong secret returns None в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

@ test_jwt_bad_secret в†’ ?String {
    : s token ( jwt_sign `payload` `goodkey` )
    : ?String result ( jwt_verify token `badkey` )
    ^ result
}

// в”Ђв”Ђ jwt_create pipeline в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

@ test_jwt_create в†’ s {
    ^ ( jwt_create `{"sub":"user1"}` `secret` )
}

// в”Ђв”Ђ jwt_claims extracts payload в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

@ test_jwt_claims в†’ s {
    : s token ( jwt_sign `mydata` `key` )
    ^ ( jwt_claims token )
}

// в”Ђв”Ђ jwt_verify valid token returns Some в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

@ test_jwt_roundtrip в†’ ?String {
    : s claims `{"id":42}`
    : s token ( jwt_sign claims `secret` )
    : ?String vr ( jwt_verify token `secret` )
    ?? vr {
        T payload в†’ { ^ @ ?String { T payload } }
        F в†’ { ^ @ ?String { F } }
    }
}

// в”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

@ main в†’ i { ^ 0 }
